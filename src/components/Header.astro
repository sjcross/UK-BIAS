---
import { Image } from "astro:assets";
import MenuButton from "./MenuButton.astro";
import UkBiasLogo from "../assets/logos/UK-BIAS_logo.svg";
import UkBiasLogoText from "../assets/logos/UK-BIAS_logo_Text.svg";
---

<header class="sticky bg-gray-100 top-0 padding-0 flex items-center h-18">
  <MenuButton />
  <Image src={UkBiasLogo} alt="UK-BIAS logo" class="ml-6 h-8 w-auto" />
  <a href={`${import.meta.env.BASE_URL}`} class="ml-6 text-4xl text-[#465786] hover:text-[#BE3E49] transition duration-200"><Image src={UkBiasLogoText} alt="UK-BIAS logo text" class="h-7 w-auto fill-red-200"/></a>
</header>
