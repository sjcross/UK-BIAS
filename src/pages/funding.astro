---
import Base from "../layouts/Base.astro";
import { Image } from "astro:assets";
import "../styles/global.css";
import UKRIBBSRCLogo from "../assets/logos/UKRI-BBSRC_logo.png";
import UKRIMRCLogo from "../assets/logos/UKRI-MRC_logo.png";

const pageTitle = "Funding";
const heading = "Funding opportunities";
---

<Base pageTitle={pageTitle} heading={heading}>
  <div class="items-start">
    <div class="float-right p-4 ml-6 mb-6 rounded-xl w-32 md:w-42 h-auto bg-gray-200">
      <p class="text-center text-lg md:text-xl mb-2">Supported by</p>
      <Image src={UKRIBBSRCLogo} alt="UKRI-BBSRC logo" class="mb-6" />
      <Image src={UKRIMRCLogo} alt="UKRI-MRC logo" class="mb-2"/>
    </div>
    <p class="mb-8 font-bold">
      Up to £2000 is available to support bioimage analysis projects via the UK
      BioImaging User Access Fund. This fund is supported by UKRI-BBSRC and
      UKRI-MRC.
    </p>

    <h2 class="text-2xl text-[#465786] mt-10 mb-4">Eligibility</h2>

    <p class="mb-2">To be eligible, you must meet the following criteria:</p>

    <ul class="ml-4 mb-8 list-disc list-inside">
      <li class="mb-2">
        Applicants must be at UKRI eligible academic research organisations.
        Please note, industry-based users are not eligible for this funding.
      </li>
      <li class="mb-2">
        Projects cannot be undertaken by UK-BIAS members at the same institution
        as the fund applicant
      </li>
      <li class="mb-2">
        A maximum of one funded application per person per year
      </li>
    </ul>

    <h2 class="text-2xl text-[#465786] mt-10 mb-4">Submission deadline</h2>

    <p class="mb-12">
      Application deadlines run on a rolling basis, with submissions closing
      every 4 months on 31st March, 31st July and 30th November.
    </p>

    <div class="flex align-center">
      <a
        href="https://www.rms.org.uk/community/networks-affiliates/bioimaginguk-network/uk-imaging-nodes/uk-bioimaging-user-access-fund.html"
        class="ml-auto mr-auto p-4 text-white rounded-2xl bg-[#ABB1C4] hover:bg-[#E8C3C9]"
        >Click here for more information and to apply</a
      >
    </div>
  </div>
</Base>
