---
import FormItem from "../components/FormItem.astro";
import Base from "../layouts/Base.astro";
const pageTitle = "Submit project";
const heading = "Submit a project";
---

<Base pageTitle={pageTitle} heading={heading}>
  <div class="flex-col">
    <p class="mb-6 font-bold">
      If you've got a project you would like us to work on, please fill in the
      form below and we will get back to you as soon as possible.
    </p>

    <p class="mb-8">
      For general enquiries, please click <a
        href={`${import.meta.env.BASE_URL}/contact-us`}
        class="text-blue-500">here</a
      >.
    </p>

    <h2 class="text-2xl text-[#465786] mt-10 mb-4">Contact details</h2>
    <form action="https://formspree.io/f/mdaqabgd" method="POST">
      <FormItem
        type="input"
        variableID="q-full-name"
        displayText="Your name:"
      />
      <FormItem type="input" variableID="q-email" displayText="Your email:" />

      <h2 class="text-2xl text-[#465786] mt-10 mb-4">Project details</h2>
      <FormItem
        type="textarea"
        variableID="q-wish-to-quantify"
        displayText="What exactly do you wish to quantify?"
        defaultText="Please list the key measurements you wish to extract from your images."
        rows="5"
      />
      <FormItem
        type="textarea"
        variableID="q-image-count-1"
        displayText="Do you currently have any images? If so, how many?"
        rows="1"
      />
      <FormItem
        type="textarea"
        variableID="q-image-count-2"
        displayText="Going forward, how many images do you anticipate having?"
        rows="1"
      />
      <FormItem
        type="textarea"
        variableID="q-shortcomings"
        displayText="Are there any known shortcomings?"
        defaultText="For example, photobleaching, mechanical drift or bleedthrough between channels."
        rows="5"
      />
      <FormItem
        type="textarea"
        variableID="q-general-background"
        displayText="General background:"
        defaultText="Please provide a brief explanation of the biological question you are attempting to answer (max 100 words). Please include some information on the nature of your samples and the system used for image acquisition."
        rows="6"
      />

      <div class="flex align-center">
        <button
          type="submit"
          class="w-64 mt-10 mb-10 ml-auto mr-auto p-2 text-white rounded-2xl bg-[#ABB1C4] hover:bg-[#E8C3C9] transition"
          >Submit</button
        >
      </div>
    </form>
  </div>
</Base>
