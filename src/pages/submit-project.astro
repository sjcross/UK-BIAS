---
import FormItem from "../components/FormItem.astro";
import Base from "../layouts/Base.astro";
const pageTitle = "Submit project";
const heading = "Submit a project";
---

<Base pageTitle={pageTitle} heading={heading}>
  <div class="flex-col text-left text-lg">
    <p class="mb-6">
      If you've got a project you would like us to work on, please fill in the
      form below and we will get back to you as soon as possible. Alternatively,
      for general enquiries please contact [TBC].
    </p>
    <form action="https://formspree.io/f/mdaqabgd" method="POST">
      <FormItem type="input" variableName="fullname" displayText="Your name:" />
      <FormItem type="input" variableName="email" displayText="Your email:" />
      <FormItem type="textarea" variableName="wish-to-quantify" displayText="What exactly do you wiah to quantify?" />
      <FormItem type="textarea" variableName="image-count-1" displayText="Do you currently have any images? If so, how many?" /> 
      
      <div class="flex align-center">
        <button
          type="submit"
          class="w-64 mt-2 ml-auto mr-auto p-2 text-white rounded-2xl bg-[#ABB1C4] hover:bg-[#E8C3C9] transition"
          >Submit</button
        >
      </div>
    </form>
  </div>
</Base>
